// Lua script to launch on boot
boot_script = "core/game/boot"

// Package to load on boot
boot_package = "boot"

window_title = "01-physics"

render_settings = {
	msaa = true
}

android = {
	render_settings = {
		msaa = false
	}
}

linux = {
	renderer = {
		resolution = [ 1280 720 ]
		vsync = true
	}
}

windows = {
	renderer = {
		resolution = [ 1280 720 ]
		vsync = true
	}
}

physics = {
	step_frequency = 240
	max_substeps = 4
}
